package ExceptionHandling;

import java.io.File;
import java.io.FileReader;

public class TryWithResource {
      public static void main(String[] args) {
    	  try(FileReader fr=new FileReader("java day 2 (qspider).txt")){
    		  int i;
		   while((i=fr.read())!=-1){
			   System.out.println((char)i);
		   }
		   fr.close();
	  }catch(Exception e) {
		  
	  }
  }
}
